<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Limpiar registros viejos de migración -->
        <delete model="ir.ui.menu" id="menu_spotify_home"/>
        <delete model="ir.ui.menu" id="menu_spotify_home_action"/>
        <delete model="ir.actions.client" id="action_spotify_home"/>

        <!-- Menu raíz -->
        <menuitem id="menu_odoo_spotify_root"
                  name="Odoo Spotify"
                  sequence="10"/>

        <!-- Artists (landing page) -->
        <menuitem id="menu_spotify_artists"
                  name="Artists"
                  parent="menu_odoo_spotify_root"
                  action="action_spotify_artist"
                  sequence="10"/>

        <!-- Albums -->
        <menuitem id="menu_spotify_albums"
                  name="Albums"
                  parent="menu_odoo_spotify_root"
                  action="action_spotify_album"
                  sequence="30"/>

        <!-- Tracks -->
        <menuitem id="menu_spotify_tracks"
                  name="Tracks"
                  parent="menu_odoo_spotify_root"
                  action="action_spotify_track"
                  sequence="40"/>

        <!-- My Playlists -->
        <menuitem id="menu_spotify_playlists"
                  name="My Playlists"
                  parent="menu_odoo_spotify_root"
                  action="action_spotify_playlist"
                  sequence="50"/>
    </data>
</odoo>
